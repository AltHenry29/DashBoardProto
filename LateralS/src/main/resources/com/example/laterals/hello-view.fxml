<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.laterals.HelloController">
  <padding>
    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
  </padding>
  <stylesheets>
    <URL value="@styles.css" />
  </stylesheets>
  <Label styleClass="form-label" text="Usuario:" />
  <TextField fx:id="txtUsuario" promptText="Ingrese su usuario" styleClass="form-input" />

  <Label styleClass="form-label" text="Contraseña:" />
  <PasswordField fx:id="txtPassword" promptText="••••••••" styleClass="form-input" />

  <Label styleClass="form-label" text="Rol de acceso:" />
  <ComboBox fx:id="cmbRol" prefWidth="250.0" promptText="Seleccione su Rol" styleClass="form-combo" />

  <VBox alignment="CENTER" spacing="10.0" style="-fx-padding: 10 0 0 0;">
    <Button fx:id="ingresar" onAction="#ingresar" prefWidth="250.0" styleClass="btn-primary" text="Ingresar" />
    <Button mnemonicParsing="false" onAction="#salir" prefWidth="250.0" styleClass="btn-secondary" text="Salir" />
  </VBox>

</VBox>
